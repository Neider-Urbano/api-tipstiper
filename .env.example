# ============================================
# .env.example — Tipster Platform
# Copia este archivo como .env y rellena los valores
# ============================================

# ─── BASE DE DATOS ───────────────────────────
# Obtén esta URL en Supabase → Settings → Database
# → Connection string → URI (modo "Transaction" para pooler)
# Formato: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# ─── API FOOTBALL ────────────────────────────
# Regístrate gratis en: https://dashboard.api-football.com
API_FOOTBALL_KEY="tu_api_key_aqui"

# ─── APP ─────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
JWT_SECRET="una-clave-secreta-larga-y-aleatoria-minimo-32-chars"

